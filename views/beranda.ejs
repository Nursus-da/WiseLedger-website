<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Keuangan</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="/css/dashboard/style.css">
</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <h1><span class="logo-1">LOG</span><span class="logo-2">O</span></h1>
        </div>
        
        <div class="menu-section">
            <a href="/beranda" class="menu-item active">
                <i class="fa-solid fa-house"></i>
                Beranda
            </a>
            
            <div class="menu-label">Manajemen</div>
            
            <a href="/arus-kas" class="menu-item">
                <i class="fa-solid fa-money-bill-transfer"></i>
                Arus Kas
            </a>
            <a href="/pendapatan" class="menu-item">
                <i class="fa-solid fa-sack-dollar"></i>
                Pendapatan
            </a>
            <a href="/pengeluaran" class="menu-item">
                <i class="fa-solid fa-filter-circle-dollar"></i>
                Pengeluaran
            </a>
            <a href="produk" class="menu-item">
                <i class="fa-solid fa-box"></i>
                Produk
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="user-profile" id="userProfileBtn">
                <i class="fa-regular fa-circle-user"></i>
                
                <div class="dropdown-menu" id="userDropdown">
                    <button type="button" class="dropdown-btn">
                        <i class="fa-solid fa-key"></i> Ubah Password
                    </button>
                    <hr>
                    <button type="button" class="dropdown-btn logout-btn">
                        <i class="fa-solid fa-right-from-bracket"></i> Logout
                    </button>
                </div>
            </div>
        </header>

        <div class="dashboard-body">
            
            <div class="row-top">
                <div class="card">
                    <h3 class="card-title">Inventaris</h3>
                    <div class="inventaris-grid" id="inventaris-data">
                        <!-- Data akan diisi menggunakan JavaScript -->
                    </div>
                </div>

                <div class="card">
                    <div class="pie-chart-container">
                        <canvas id="pieChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="row-bottom">
                <div class="card">
                    <div class="header-chart-area">
                        <h3 class="card-title">Keuntungan Tahun 2025</h3>
                        <select class="dropdown-filter">
                            <option>Tahun</option>
                            <option>2024</option>
                            <option>2025</option>
                        </select>
                    </div>
                    <div class="line-chart-container">
                        <canvas id="lineChart"></canvas>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script>
        // 1. Populate Inventaris Data (repeating pattern from screenshot)
        const inventarisItems = [
            "Lumpia : 10 pcs", "Lumpia : 10 pcs", "Lumpia : 10 pcs",
            "Pangsit : 10 pcs", "Pangsit : 10 pcs", "Pangsit : 10 pcs",
            "Daging : 1 kg", "Daging : 1 kg", "Daging : 1 kg",
            "Lumpia : 10 pcs", "Lumpia : 10 pcs", "Lumpia : 10 pcs",
            "Pangsit : 10 pcs", "Pangsit : 10 pcs", "Pangsit : 10 pcs",
            "Daging : 1 kg", "Daging : 1 kg", "Daging : 1 kg",
            "Lumpia : 10 pcs", "Lumpia : 10 pcs", "Lumpia : 10 pcs",
            "Pangsit : 10 pcs", "Pangsit : 10 pcs", "Pangsit : 10 pcs"
        ];
        
        const invGrid = document.getElementById('inventaris-data');
        inventarisItems.forEach(item => {
            const div = document.createElement('div');
            div.textContent = item;
            invGrid.appendChild(div);
        });

        // 2. Setup Pie Chart
        const ctxPie = document.getElementById('pieChart').getContext('2d');
        new Chart(ctxPie, {
            type: 'pie',
            data: {
                labels: ['Keuntungan', 'Modal'],
                datasets: [{
                    data: [100, 50], // 66.67% and 33.33%
                    backgroundColor: ['#8884d8', '#ff8042'], 
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: {
                            usePointStyle: true,
                            boxWidth: 8,
                            font: { size: 11 }
                        }
                    }
                }
            }
        });

        // 3. Setup Line (Area) Chart
        const ctxLine = document.getElementById('lineChart').getContext('2d');
        
        // Create Gradient for Line Chart
        let gradientFill = ctxLine.createLinearGradient(0, 0, 0, 350);
        gradientFill.addColorStop(0, 'rgba(136, 132, 216, 0.4)');
        gradientFill.addColorStop(1, 'rgba(136, 132, 216, 0.05)');

        new Chart(ctxLine, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agu', 'Sep', 'Okt', 'Nov', 'Des'],
                datasets: [{
                    label: 'Keuntungan',
                    data: [82, 70, 44, 24, 44, 44, 55, 68, 80, 89, 88, 94], // Estimated data points from image
                    borderColor: '#8884d8',
                    backgroundColor: gradientFill,
                    borderWidth: 2,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#8884d8',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    fill: true,
                    tension: 0.4 // Makes the line smooth (curved)
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false } // Hidden legend for line chart
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100,
                        grid: {
                            color: '#f3f4f6',
                            drawBorder: false,
                            borderDash: [5, 5] // Dashed grid lines
                        },
                        ticks: { color: '#9ca3af', font: { size: 11 } }
                    },
                    x: {
                        grid: {
                            color: '#f3f4f6',
                            drawBorder: false,
                            borderDash: [5, 5]
                        },
                        ticks: { color: '#9ca3af', font: { size: 11 } }
                    }
                }
            }
        });
    </script>
    <script src="/js/main.js"></script>
    <script src="/js/utils/get.js"></script>
    <script src="/js/utils/utils.js"></script>
    <script src="/js/auth/beranda.js"></script>
</body>
</html>