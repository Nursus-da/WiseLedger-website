<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arus Kas - Dashboard Keuangan</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard/style.css">
</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <h1><span class="logo-1">LOG</span><span class="logo-2">O</span></h1>
        </div>
        
        <div class="menu-section">
            <a href="/beranda" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Beranda
            </a>
            
            <div class="menu-label">Manajemen</div>
            
            <a href="/arus-kas" class="menu-item active">
                <i class="fa-solid fa-money-bill-transfer"></i>
                Arus Kas
            </a>
            <a href="/pendapatan" class="menu-item">
                <i class="fa-solid fa-sack-dollar"></i>
                Pendapatan
            </a>
            <a href="/pengeluaran" class="menu-item">
                <i class="fa-solid fa-filter-circle-dollar"></i>
                Pengeluaran
            </a>
            <a href="/produk" class="menu-item">
                <i class="fa-solid fa-box"></i>
                Produk
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="user-profile">
                <i class="fa-regular fa-circle-user"></i>
            </div>
        </header>

        <div class="dashboard-body">
            
            <h2 class="page-title">Arus Kas</h2>

            <div class="summary-cards">
                <div class="card card-light-blue" id="card-laba">
                    
                </div>

                <div class="card card-pendapatan" id="card-pendapatan">
                    
                </div>

                <div class="card card-pengeluaran" id="card-pengeluaran">
                    
                </div>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <th>Tipe</th>
                            <th>Status</th>
                            <th>Nominal</th>
                        </tr>
                    </thead>
                    <tbody id="table-aruskas">
                        
                    </tbody>
                </table>
                
                <div class="pagination-footer">
                    <div class="showing-text">Showing 1 to 4 of 4 entries</div>
                    <div class="pagination-controls">
                        <button class="page-btn"><i class="fa-solid fa-chevron-left"></i></button>
                        <button class="page-btn active">1</button>
                        <button class="page-btn"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <script src="/js/utilsAuth/getToken.js"></script>
    <script src="/js/utilsAuth/utils.js"></script>
    <script src="/js/auth/arus-kas.js"></script>
    <script src="/js/utilsArusKasList/utilsGetAruskas.js"></script>
    <script src="/js/verifyList/getArusKas.js"></script>
</body>
</html>