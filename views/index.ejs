<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WiseLedger Landing Page</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header class="navbar d-flex justify-content-between align-items-center">
        <a href="#" class="logo-text">
            <span class="logo-highlight">LO</span>GO
        </a>
        <div>
            <a href="login" class="btn btn-custom-outline">Sign in</a>
            <a href="register" class="btn btn-custom-solid">Sign up</a>
        </div>
    </header>

    <main class="container hero-section">
        <div class="row align-items-center w-100">
            
            <div class="col-lg-6 col-md-12 mb-5 mb-lg-0">
                <h1 class="hero-title">
                    Manage Your<br>
                    Money Smarter<br>
                    with <span class="text-brand">WiseLedger</span>
                </h1>
                <p class="hero-subtitle">
                    Plan your monthly budget, track daily expenses, and reflect on your spending habits in one simple platform designed for smarter financial decisions.
                </p>
            </div>

            <div class="col-lg-6 col-md-12">
                <div class="hero-image-container">
                    <div class="hero-image-bg"></div>
                    <img src="https://dummyimage.com/300x350/transparent/fff.png&text=Letakkan+Gambar+Mascot+Di+Sini" alt="WiseLedger Mascot" class="hero-image">
                </div>
            </div>

        </div>
    </main>

    <footer class="footer-bar"></footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>