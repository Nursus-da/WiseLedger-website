<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Keuangan - Pendapatan</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/dashboard/styles.css">

</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <h1><span class="logo-1">LOG</span><span class="logo-2">O</span></h1>
        </div>
        
        <div class="menu-section">
            <a href="/beranda" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Beranda
            </a>
            
            <div class="menu-label">Manajemen</div>
            
            <a href="/arus-kas" class="menu-item">
                <i class="fa-solid fa-money-bill-transfer"></i>
                Arus Kas
            </a>
            <a href="/pendapatan" class="menu-item active">
                <i class="fa-solid fa-sack-dollar"></i>
                Pendapatan
            </a>
            <a href="/pengeluaran" class="menu-item">
                <i class="fa-solid fa-filter-circle-dollar"></i>
                Pengeluaran
            </a>
            <a href="/produk" class="menu-item">
                <i class="fa-solid fa-box"></i>
                Produk
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="user-profile">
                <i class="fa-regular fa-circle-user"></i>
            </div>
        </header>

        <div class="dashboard-body">
            
            <div class="page-header">
                <h2 class="page-title">Pendapatan</h2>
                <button class="btn-add" id="btn-tambah-pendapatan"><i class="fa-solid fa-plus"></i> Pendapatan</button>
            </div>

            <div class="summary-cards">
                <div class="card card-light-blue" id="pendapatan-bulan-ini">

                </div>

                <div class="card card-grey-blue" id="pendapatan-tertinggi">
                    
                </div>

                <div class="card card-bright-blue">
                    <h4>Transaksi tertinggi</h4>
                    <h2>Rp. 0</h2>
                    <p><a href="#">Transaksi A</a></p>
                </div>
            </div>

            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Tanggal</th>
                            <!-- <th>Deskripsi</th> -->
                            <th>Tipe</th>
                            <th>Jumlah</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody id="get">
                        
                    </tbody>
                </table>

                <div class="pagination-footer">
                    <span>Showing 1 to 4 of 4 entries</span>
                    <div class="pagination-controls">
                        <button class="page-btn"><i class="fa-solid fa-chevron-left"></i></button>
                        <button class="page-btn active">1</button>
                        <button class="page-btn"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <div id="modalPendapatan" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <i class="fa-solid fa-arrow-left btn-back" id="btn-tutup-modal"></i>
            </div>
            
            <div class="modal-body">
                <form id="formPendapatan">
                    <div class="form-group">
                        <label>Tipe</label>
                        <div class="input-icon-wrapper">
                            <input type="text" id="tipe" value="Pendapatan" disabled>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Tanggal</label>
                        <div class="input-icon-wrapper">
                            <input type="date" id="tanggal" placeholder="Pilih Tanggal">
                            <i class="fa-regular fa-calendar"></i>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label>Deskripsi</label>
                        <input type="text" id="deskripsi" placeholder="Ketik disini...">
                    </div>
                    
                    <div class="form-group">
                        <label>Jumlah</label>
                        <input type="number" id="jumlah" placeholder="Rp. Ketik disini...">
                    </div>
                    
                    <div class="form-group">
                        <label>Simpan ke</label>
                        <div class="input-icon-wrapper">
                            <select id="simpan" required>
                                <option value="" disabled selected hidden>Pilih status</option>
                                <option value="Rekening">Rekening</option>
                                <option value="Uang Kas">Uang Kas</option>
                            </select>
                            <i class="fa-solid fa-chevron-down"></i>
                        </div>
                    </div>
                    
                    <button type="submit" class="btn-submit-form">Tambah</button>
                </form>
            </div>
        </div>
    </div>

    <script src="/js/utilsAuth/getToken.js"></script>
    <script src="/js/utilsAuth/utils.js"></script>
    <script src="/js/authAndformsetup/pendapatan.js"></script>
    <script src="/js/utilsArusKasList/utilsGetPendapatan.js"></script>
    <script src="/js/aruskaslist/getPendapatan.js"></script>
    <script src="/js/updatedelete/udpendapatan/delete.js"></script>
    <script src="/js/updatedelete/udpendapatan/utils.js"></script>

</body>
</html>