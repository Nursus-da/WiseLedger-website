<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Halaman Produk</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/dist/produk.css">
</head>
<body>

    <aside class="sidebar">
        <div class="logo-container">
            <img src="/assets/image/logo.png" alt="logo" class="sidebar-logo">
        </div>
        
        <div class="menu-section">
            <a href="/beranda" class="menu-item">
                <i class="fa-solid fa-house"></i>
                Beranda
            </a>
            
            <div class="menu-label">Manajemen</div>
            
            <a href="/arus-kas" class="menu-item">
                <i class="fa-solid fa-money-bill-transfer"></i>
                Arus Kas
            </a>
            <a href="/pendapatan" class="menu-item">
                <i class="fa-solid fa-sack-dollar"></i>
                Pendapatan
            </a>
            <a href="/pengeluaran" class="menu-item">
                <i class="fa-solid fa-filter-circle-dollar"></i>
                Pengeluaran
            </a>
            <a href="/produk" class="menu-item active">
                <i class="fa-solid fa-box"></i>
                Produk
            </a>
        </div>
    </aside>

    <main class="main-content">
        <header class="topbar">
            <div class="user-profile">
                <i class="fa-regular fa-circle-user"></i>
            </div>
        </header>

        <div class="dashboard-body">
            
            <div class="page-header">
                <h2 class="page-title">Produk</h2>
                <button class="btn-add"><i class="fa-solid fa-plus"></i> Produk</button>
            </div>

            <div class="card">
                
                <div class="table-container">
                    <table class="product-table">
                        <thead>
                            <tr>
                                <th>Nama Produk/Layanan</th>
                                <th>Harga</th>
                                <!-- <th>Biaya</th> -->
                                <th>Stok</th>
                                <th>Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="list-produk">
                            
                        </tbody>
                    </table>
                </div>

                <div class="pagination-area">
                    <div class="showing-text">Showing 1 to 4 of 4 entries</div>
                    <div class="pagination">
                        <button class="page-btn"><i class="fa-solid fa-chevron-left"></i></button>
                        <button class="page-btn active">1</button>
                        <button class="page-btn"><i class="fa-solid fa-chevron-right"></i></button>
                    </div>
                </div>

            </div>
        </div>

    <div id="modalProduk" class="modal-overlay">
        <div class="modal-container">
            <div class="modal-header">
                <button id="btnTutupModal" class="btn-back">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>
            </div>

            <div class="modal-body">
                <form id="formTambahProduk">
                    <div class="form-group">
                        <label>Kategori</label>
                        <select class="form-input" id="form-input-kategori">
                            <option value="" disabled selected>Pilih Kategori</option>
                            <option value="Produk">Produk</option>
                            <option value="Jasa">Jasa</option>
                        </select>
                    </div>
                
                    <div class="form-group">
                        <label>Stok</label>
                        <input type="text" class="form-input" id="form-input-stok" placeholder="Ketik disini...">
                    </div>
                
                    <div class="form-group">
                        <label>Nama Jasa/Produk</label>
                        <input type="text" class="form-input" id="form-input-produk" placeholder="Ketik disini...">
                    </div>
                
                    <div class="form-group">
                        <label>Harga</label>
                        <input type="text" class="form-input" id="form-input-harga" placeholder="Rp. Ketik Harga Jasa/Produk">
                    </div>
                
                    <div class="form-group">
                        <label>Biaya</label>
                        <input type="text" class="form-input" id="form-input-biaya" placeholder="Rp. Ketik Biaya Jasa/Produk">
                    </div>
                
                    <button type="submit" class="btn-submit">Tambah</button>
                </form>
            </div>
        </div>
    </div>

    </main>

    <script src="/dist/produk.js"></script>

</body>
</html>